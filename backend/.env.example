# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tolkcheck

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Whisper ───────────────────────────────────────────────
WHISPER_MODEL=large-v3
# Use "cuda" for GPU, "cpu" for CPU-only
WHISPER_DEVICE=cpu
# Use "float16" on GPU, "int8" on CPU
WHISPER_COMPUTE_TYPE=int8

# ── HuggingFace ───────────────────────────────────────────
# Required to download pyannote/speaker-diarization-3.1
# Accept the model license at https://hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_your_token_here

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here
LLM_MODEL=claude-sonnet-4-6

# ── Auth ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme_replace_with_openssl_rand_hex_32
